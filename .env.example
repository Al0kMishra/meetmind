# ── LLM Provider ─────────────────────────────────────────────
# Choose one: groq | openai | anthropic | gemini
LLM_PROVIDER=groq

# Groq (recommended — free, fast)
GROQ_API_KEY=gsk_...

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# ── Whisper ──────────────────────────────────────────────────
# Model size: tiny | base | small | medium
# base = fast, small = more accurate
WHISPER_MODEL=base

# ── Speaker Diarization ──────────────────────────────────────
# Get token: https://huggingface.co/settings/tokens
# Accept terms: https://hf.co/pyannote/speaker-diarization-3.1
# Leave blank to skip diarization (all speakers = SPEAKER_00)
HF_TOKEN=hf_...

# ── Audio ─────────────────────────────────────────────────────
# Run: python audio/list_devices.py to find your mic index
# Leave blank for system default
AUDIO_DEVICE_INDEX=

# ── Intelligence ──────────────────────────────────────────────
# How often (seconds) to call LLM for extraction
LLM_INTERVAL_SECONDS=120
